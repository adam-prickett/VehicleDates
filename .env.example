# DVLA Vehicle Enquiry Service API key
# Apply for one at: https://developer-portal.driver-vehicle-licensing.api.gov.uk/
DVLA_API_KEY=your_dvla_api_key_here

# SQLite database file path (optional, defaults to ./vehicles.db)
DATABASE_URL=./vehicles.db

# Server port (optional, defaults to 3001)
PORT=3001
